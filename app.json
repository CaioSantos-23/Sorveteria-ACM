{
  "expo": {
    "name": "Gelato MEC",
    "slug": "gelato-mec",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo_gelato_mec.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo_gelato_mec.png",
      "resizeMode": "contain",
      "backgroundColor": "#3D1A78"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gelato.mec",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#3D1A78",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.gelato.mec",
      "config": {
        "googleMaps": {
          "apiKey": "SUA_CHAVE_AQUI"
        }
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Permitir que o Gelato MEC acesse sua localização."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "web": {
      "favicon": "./assets/icone_app.png"
    },
    "extra": {
      "eas": {
        "projectId": "2cac15e8-43a9-460f-8f8e-8900918a7e43"
      }
    },
    "owner": "xaneu23"
  }
}
