{
  "expo": {
    "name": "Gelato MEC",
    "slug": "gelato-mec",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo_gelato_mec.jpeg",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo_gelato_mec.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#3D1A78"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gelato.mec",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#3D1A78",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.gelato.mec",
      "config": {
        "googleMaps": {
          "apiKey": "SUA_CHAVE_AQUI"
        }
      }
    },
    "plugins": [
      ["expo-location", { "locationAlwaysAndWhenInUsePermission": "Permitir que o Gelato MEC acesse sua localização." }]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "fb977c48-bf59-4818-9503-8b8bfe90f98f"
      }
    }
  }
}
